# =============================================================================
# Educational project — grading requirement
# The SQLite database (db/wall.db) and static images under assets/img/ MUST
# remain tracked in Git. Do NOT add rules that ignore:
#   - db/*.db / db/*.sqlite
#   - assignment image assets
#
# SQLite WAL mode creates ephemeral companion files alongside *.db — ignore those only.
# =============================================================================

database/*.db-wal
database/*.db-shm

.DS_Store
*.log

# Environment / dependencies (not part of this stack)
/vendor/
/node_modules/
.env

# Editor junk
.vscode/
.idea/
*.swp

# Python bytecode (generated locally when running/importing .py files — not needed in Git)
__pycache__/
*.py[cod]
*$py.class

# Claude Code / local assistant settings (not part of the web app)
.claude/
